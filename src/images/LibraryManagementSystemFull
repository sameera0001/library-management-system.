    private void openViewTransaction(JFrame parent) {
        JFrame f = new JFrame("View Transactions");
        f.setExtendedState(JFrame.MAXIMIZED_BOTH);
        f.setLayout(new BorderLayout());

        String[] columns = { "ID", "Student", "Book", "Date", "Due", "Status" };
        DefaultTableModel model = new DefaultTableModel(columns, 0);
        JTable table = new JTable(model);
        table.setFont(new Font("Arial", Font.PLAIN, 18));
        table.setRowHeight(30);

        try (Connection con = DriverManager.getConnection(DB_URL, DB_USER, DB_PASS)) {
            Statement st = con.createStatement();
            ResultSet rs = st.executeQuery("SELECT * FROM transactions");
            while (rs.next()) {
                Vector<Object> row = new Vector<>();
                row.add(rs.getInt("id"));
                row.add(rs.getString("student_id"));
                row.add(rs.getString("book_id"));
                row.add(rs.getDate("issue_date"));
                row.add(rs.getDate("due_date"));
                row.add(rs.getString("status"));
                model.addRow(row);
            }
        } catch (SQLException e) {
            e.printStackTrace();
        }

        f.add(new JScrollPane(table), BorderLayout.CENTER);
        JButton back = new JButton("Back to Dashboard");
        styleButton(back, Color.BLACK);
        back.addActionListener(e -> {
            f.dispose();
            parent.setVisible(true);
        });
        f.add(back, BorderLayout.SOUTH);
        f.setVisible(true);
    }

    private void styleButton(JButton btn, Color color) {
        btn.setBackground(color);
        btn.setForeground(Color.WHITE);
        btn.setFont(new Font("Arial", Font.BOLD, 18));
        btn.setFocusPainted(false);
        btn.setBorder(BorderFactory.createLineBorder(Color.WHITE, 1));
    }

