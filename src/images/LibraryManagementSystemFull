        });
        bg.add(backBtn);

        JLabel title = new JLabel("Student Registration");
        title.setBounds(100, 100, 600, 60);
        title.setFont(new Font("Arial", Font.BOLD, 42));
        bg.add(title);

        JTextField[] fields = new JTextField[5];
        String[] labels = {"Student ID", "Name", "Course", "Branch", "Semester"};
        int y = 200;
        for (int i = 0; i < labels.length; i++) {
            JLabel lbl = new JLabel(labels[i]);
            lbl.setBounds(100, y, 200, 40);
            lbl.setFont(new Font("Arial", Font.BOLD, 26));
            bg.add(lbl);

            JTextField tf = new JTextField();
            tf.setBounds(320, y, 350, 40);
            tf.setFont(new Font("Arial", Font.PLAIN, 20));
            bg.add(tf);
            fields[i] = tf;
            y += 75;
        }

        JButton saveBtn = new JButton("Register Student");
        saveBtn.setBounds(100, y + 30, 250, 55);
        styleButton(saveBtn, new Color(0, 100, 200));
        saveBtn.addActionListener(e -> {
            String sid = fields[0].getText();
            String name = fields[1].getText();
            String course = fields[2].getText();
            String branch = fields[3].getText();
            String sem = fields[4].getText();

            if (sid.isEmpty() || name.isEmpty()) {
                JOptionPane.showMessageDialog(null, "Student ID and Name required!");
                return;
            }

            try (Connection con = DriverManager.getConnection(DB_URL, DB_USER, DB_PASS)) {
                String sql = "INSERT INTO students (student_id, name, course, branch, semester) VALUES (?, ?, ?, ?, ?)";
                PreparedStatement pst = con.prepareStatement(sql);
                pst.setString(1, sid);
                pst.setString(2, name);
                pst.setString(3, course);
                pst.setString(4, branch);
                pst.setString(5, sem);
                int rows = pst.executeUpdate();
                if (rows > 0) JOptionPane.showMessageDialog(null, "Student Registered Successfully!");
                else JOptionPane.showMessageDialog(null, "Failed to register student!");
            } catch (SQLException ex) {
                ex.printStackTrace();
                JOptionPane.showMessageDialog(null, "DB Error: " + ex.getMessage());
            }
        });
        bg.add(saveBtn);
        f.setVisible(true);
    }

